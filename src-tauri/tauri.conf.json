{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GoldSrc Config Engineer",
  "version": "3.2.1",
  "identifier": "com.cspres.goldsr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GoldSrc Config Engineer",
        "width": 1100,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
