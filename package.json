{
  "name": "goldsr-config-engineer",
  "private": true,
  "version": "3.2.1",
  "description": "GoldSrc Config Engineer — генератор CFG для CS 1.6 (Tauri + React + Rust)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/under2ker/GoldSrc-Config-Engineer.git"
  },
  "bugs": {
    "url": "https://github.com/under2ker/GoldSrc-Config-Engineer/issues"
  },
  "homepage": "https://github.com/under2ker/GoldSrc-Config-Engineer#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "cargo test --workspace && cargo check --workspace && npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:portable:bundle": "npm run build && tauri build --no-bundle",
    "build:portable": "npm run build:portable:bundle && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "build:installer": "npm run build && tauri build"
  },
