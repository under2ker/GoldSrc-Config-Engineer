  "utility": {
    "_section_comment": "Utility toggle/cycle aliases",
    "aliases": [
      {
        "name": "toggle_netgraph",
        "type": "cycle",
        "states": [
          {"name": "ng_0", "command": "net_graph 0; echo NetGraph: OFF", "next": "ng_1"},
          {"name": "ng_1", "command": "net_graph 1; echo NetGraph: 1", "next": "ng_2"},
          {"name": "ng_2", "command": "net_graph 2; echo NetGraph: 2", "next": "ng_3"},
          {"name": "ng_3", "command": "net_graph 3; echo NetGraph: 3", "next": "ng_0"}
        ],
        "description": "Переключение netgraph 0/1/2/3",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "toggle_fps",
        "type": "cycle",
        "states": [
          {"name": "fps_0", "command": "cl_showfps 0; echo FPS: OFF", "next": "fps_1"},
          {"name": "fps_1", "command": "cl_showfps 1; echo FPS: ON", "next": "fps_2"},
          {"name": "fps_2", "command": "cl_showfps 2; echo FPS: Extended", "next": "fps_0"}
        ],
        "description": "Переключение FPS-счётчика",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "toggle_xhair",
        "type": "cycle",
        "states": [
          {"name": "xhair_1", "command": "cl_crosshair_size small; cl_crosshair_color \"50 250 50\"; echo Crosshair: Small Green", "next": "xhair_2"},
          {"name": "xhair_2", "command": "cl_crosshair_size medium; cl_crosshair_color \"255 255 0\"; echo Crosshair: Medium Yellow", "next": "xhair_3"},
          {"name": "xhair_3", "command": "cl_crosshair_size large; cl_crosshair_color \"250 50 50\"; echo Crosshair: Large Red", "next": "xhair_4"},
          {"name": "xhair_4", "command": "cl_crosshair_size auto; cl_crosshair_color \"50 50 250\"; echo Crosshair: Auto Blue", "next": "xhair_1"}
        ],
        "description": "Цикл кроссхейров",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "toggle_hand",
        "type": "toggle",
        "on": {"command": "cl_righthand 1; echo Hand: RIGHT"},
        "off": {"command": "cl_righthand 0; echo Hand: LEFT"},
        "description": "Смена руки",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "toggle_radar",
        "type": "toggle",
        "on": {"command": "cl_radartype 0; echo Radar: Normal"},
        "off": {"command": "cl_radartype 1; echo Radar: Solid"},
        "description": "Тип радара",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "toggle_viewmodel",
        "type": "toggle",
        "on": {"command": "r_drawviewmodel 1; echo Viewmodel: ON"},
        "off": {"command": "r_drawviewmodel 0; echo Viewmodel: OFF"},
        "description": "Показать/скрыть оружие",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "vol_toggle",
        "type": "toggle",
        "on": {"command": "volume 0.5; echo Volume: ON"},
        "off": {"command": "volume 0; echo Volume: OFF"},
        "description": "Вкл/выкл звук",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "demo_rec",
        "type": "simple",
        "command": "record auto_demo; echo Demo recording started",
        "description": "Запись демо",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "demo_stp",
        "type": "simple",
        "command": "stop; echo Demo recording stopped",
        "description": "Остановка записи демо",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "take_screenshot",
        "type": "simple",
        "command": "screenshot",
        "description": "Скриншот",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "turn_180",
        "type": "simple",
        "command": "cl_yawspeed 9999; +left; wait; wait; -left; cl_yawspeed 210",
        "description": "Быстрый разворот ~180° (требует wait на сервере)",
        "safety": "WAIT",
        "required": false
      },
      {
        "name": "spec_next",
        "type": "simple",
        "command": "spec_mode",
        "description": "Следующий режим наблюдателя",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "mode_classic",
        "type": "simple",
        "command": "exec config/modes/classic.cfg; echo Mode: Classic",
        "description": "Загрузить режим Classic",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "mode_kz",
        "type": "simple",
        "command": "exec config/modes/kz.cfg; echo Mode: KZ",
        "description": "Загрузить режим KZ",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "mode_surf",
        "type": "simple",
        "command": "exec config/modes/surf.cfg; echo Mode: Surf",
        "description": "Загрузить режим Surf",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "mode_dm",
        "type": "simple",
        "command": "exec config/modes/dm.cfg; echo Mode: Deathmatch",
        "description": "Загрузить режим Deathmatch",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "sens_toggle",
        "type": "cycle",
        "states": [
          {"name": "sens_normal", "command": "sensitivity 2.5; echo Sensitivity: Normal", "next": "sens_awp"},
          {"name": "sens_awp", "command": "sensitivity 1.5; echo Sensitivity: AWP", "next": "sens_normal"}
        ],
        "description": "Переключение чувствительности Normal / AWP (цепочка)",
        "safety": "SAFE",
        "required": false
      }
    ]
  },
