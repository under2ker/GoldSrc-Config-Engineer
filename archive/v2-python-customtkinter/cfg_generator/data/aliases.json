{
  "movement": {
    "_section_comment": "Movement aliases",
    "aliases": [
      {
        "name": "+duckjump",
        "plus": "+jump; +duck",
        "minus": "-jump; -duck",
        "description": "Прыжок с приседом",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "+jumpthrow",
        "plus": "+jump; -attack",
        "minus": "-jump",
        "description": "Бросок гранаты с прыжка",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "+quickswitch",
        "plus": "lastinv; wait; lastinv",
        "minus": "",
        "description": "Быстрая смена оружия туда-обратно",
        "safety": "WAIT",
        "required": true
      },
      {
        "name": "+ladderup",
        "plus": "+forward; +moveright",
        "minus": "-forward; -moveright",
        "description": "Быстрый подъём по лестнице",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "+ladderdown",
        "plus": "+back; +moveleft",
        "minus": "-back; -moveleft",
        "description": "Быстрый спуск по лестнице",
        "safety": "SAFE",
        "required": true
      },
      {
        "name": "+jumpduck",
        "plus": "+duck; +jump",
        "minus": "-duck; -jump",
        "description": "Присед перед прыжком (KZ / block jump)",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "+bhop_scroll",
        "plus": "+jump",
        "minus": "-jump",
        "description": "Бхоп через колёсико (легитимный +jump)",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "+highjump",
        "plus": "+duck; wait; -duck; wait; wait; +jump; +duck",
        "minus": "-jump; -duck",
        "description": "HighJump (block): duck -> release -> pause -> jump+duck, max height",
        "safety": "WAIT",
        "required": false
      },
      {
        "name": "+countjump",
        "plus": "+duck; wait; -duck; wait; +jump; +duck",
        "minus": "-jump; -duck",
        "description": "Countjump (CJ): duck, unduck, jump, duck (classic KZ)",
        "safety": "WAIT",
        "required": false
      },
      {
        "name": "+longjump",
        "plus": "+jump; +duck",
        "minus": "-jump; -duck",
        "description": "Longjump (LJ): синхронный jump+duck в длину (W + стрейф)",
        "safety": "SAFE",
        "required": false
      },
      {
        "name": "kz_blockjump_chain",
        "type": "kz_chain",
        "chain_id": "kz_blockjump",
        "steps": [
          "+duck",
          "-duck",
          "+jump",
          "+duck",
          "-jump; -duck"
        ],
        "description": "HJ/CJ without wait: 5x kz_blockjump_go (duck, unduck, jump, duck, release)",
        "safety": "SAFE",
        "required": false
      }
    ]
  },
